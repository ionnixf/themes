configuration {
    modi: "drun,run,window";
    show-icons: true;
    display-drun: "Apps";
    display-run: "Run";
    display-window: "Windows";
    drun-display-format: "{name}";
    font: "JetBrainsMono Nerd Font 11";
    icon-theme: "Papirus-Dark";
    terminal: "alacritty";
    matching: "fuzzy";
    sort: true;
    disable-history: false;
    hide-scrollbar: true;
    sidebar-mode: false;
}

@theme "neutral"

[global]
    monitor = 0
    follow = mouse
    width = 360
    height = (0, 100)
    origin = top-right
    offset = (14, 48)
    notification_limit = 4
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 0
    progress_bar_min_width = 120
    progress_bar_max_width = 320
    indicate_hidden = yes
    transparency = 12
    separator_height = 1
    padding = 12
    horizontal_padding = 14
    text_icon_padding = 12
    frame_width = 1
    frame_color = "#555555"
    separator_color = frame
    sort = yes
    font = JetBrainsMono Nerd Font 10
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = no
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    corner_radius = 0

[urgency_low]
    background = "#181818e6"
    foreground = "#b0b0b0"
    timeout = 4

[urgency_normal]
    background = "#181818e6"
    foreground = "#e8e8e8"
    timeout = 6

[urgency_critical]
    background = "#181818f2"
    foreground = "#f2f2f2"
    frame_color = "#b85c5c"
    timeout = 0
